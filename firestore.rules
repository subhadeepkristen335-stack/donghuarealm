rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // In a real app, this would read from a 'roles' collection
    // or, more securely, check for a custom claim on the auth token.
    // You can set this claim using the Firebase Admin SDK.
    function isAdmin() {
      // Temporarily allowing any authenticated user to write for debugging
      // We will revert this once we confirm if the issue is App Check or Rules
      return request.auth != null;
    }

    // ===============================================================
    // Public, Read-Only Collections (for guests)
    // Writable only by admins.
    // ===============================================================
    match /anime/{animeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /episodes/{episodeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===============================================================
    // Comments Collection
    // ===============================================================
    match /comments/{commentId} {
      // Anyone can read comments
      allow read: if true;

      // Anyone can create valid comments
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 50
                    && request.resource.data.body is string
                    && request.resource.data.body.size() > 0 && request.resource.data.body.size() < 1000
                    && request.resource.data.episodeId is string
                    && request.resource.data.createdAt is string;

      // Only admins can update or delete guest comments
      allow update, delete: if isAdmin();
    }

    // ===============================================================
    // User-Private Collections
    // ===============================================================
    match /bookmarks/{bookmarkId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.animeId is string;
    }

    match /watch_history/{historyId} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.animeId is string
                    && request.resource.data.episodeId is string
                    && request.resource.data.progress is number;
    }
  }
}